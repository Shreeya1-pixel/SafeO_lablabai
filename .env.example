# =============================================================================
# SafeO — copy to backend/.env and fill in (never commit .env)
# =============================================================================

# --- API auth (Universal /v1/* routes) ---
SAFEO_API_KEYS=internal,your-demo-key

# --- Tier 3: local vLLM only (no OpenAI / cloud LLM) ---
SECUREC_ENABLE_LLM_AUGMENTATION=true
SAFEO_LLM_SERVER_URL=http://localhost:8000/v1
SAFEO_LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# --- Band of Agents (hackathon) — https://band.ai ---
# Create 4 external agents: SafeO-Multilingual, Policy, Forensics, Remediation
# Promo: BANDHACK26 (1 month Band Pro)
BAND_ENABLED=true
BAND_MULTILINGUAL_AGENT_ID=
BAND_MULTILINGUAL_API_KEY=
BAND_POLICY_AGENT_ID=
BAND_POLICY_API_KEY=
BAND_FORENSICS_AGENT_ID=
BAND_FORENSICS_API_KEY=
BAND_REMEDIATION_AGENT_ID=
BAND_REMEDIATION_API_KEY=

# Set BAND_ENABLED=false to run without Band (graceful fallback)

# --- Jira escalation (configured in Odoo UI; reference for your setup) ---
# Odoo: Settings → SafeO → Jira Integration
# Auto-creates SEC-* tickets when risk ≥ 70% (BLOCK)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SEC

# --- Optional AMD / GPU ---
# SAFEO_AMD_DEVICE=cuda
# SAFEO_ENABLE_GPU_METRICS=true
# SAFEO_TIER2_MODEL_NAME=distilbert-base-uncased
# SAFEO_MULTILINGUAL_MODEL_NAME=aubmindlab/bert-base-arabertv2
